; Generate and compile property-level runtime witness references. Missing
; modules and incompatible unary toString functions fail the build.

(executable
 (name gen_css_types_witnesses)
 (modules gen_css_types_witnesses)
 (libraries Css_grammar))

(rule
 (with-stdout-to
  css_types_witnesses.ml
  (run ./gen_css_types_witnesses.exe)))

(test
 (name css_types_witnesses)
 (modules css_types_witnesses)
 (libraries styled-ppx.native))

(rule
 (alias test-runtime)
 (deps css_types_witnesses.exe)
 (action
  (run %{deps})))
