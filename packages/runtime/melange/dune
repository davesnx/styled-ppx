(library
 (name styled_ppx_runtime_melange)
 (public_name styled-ppx.melange)
 (modes melange)
 (wrapped false)
 (libraries styled-ppx.stdlib-ban reason-react)
 ; Ban direct Stdlib usage: everything must go through Kloth. See
 ; packages/runtime/stdlib-ban/Styled_ppx_stdlib_ban.mli.
 (flags (:standard -open Styled_ppx_stdlib_ban -alert @banned))
 (preprocess
  (pps melange.ppx -alert -deprecated)))

(copy_files#
 (mode fallback)
 (files ../native/shared/**[!.pp].ml))

(copy_files#
 (only_sources)
 (files ./../native/Kloth.mli))
