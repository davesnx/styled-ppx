/* Modern CSS Layout Properties */

/* place-content */
[%css {|place-content: center|}];
[%css {|place-content: start|}];
[%css {|place-content: end|}];
[%css {|place-content: space-between|}];
[%css {|place-content: space-around|}];
[%css {|place-content: space-evenly|}];
[%css {|place-content: stretch|}];
[%css {|place-content: center start|}];
[%css {|place-content: start end|}];
[%css {|place-content: space-between center|}];

/* place-items */
[%css {|place-items: center|}];
[%css {|place-items: start|}];
[%css {|place-items: end|}];
[%css {|place-items: stretch|}];
[%css {|place-items: baseline|}];
[%css {|place-items: center start|}];
[%css {|place-items: start end|}];

/* place-self */
[%css {|place-self: auto|}];
[%css {|place-self: center|}];
[%css {|place-self: start|}];
[%css {|place-self: end|}];
[%css {|place-self: stretch|}];
[%css {|place-self: center start|}];
[%css {|place-self: start end|}];

/* accent-color */
[%css {|accent-color: auto|}];
[%css {|accent-color: red|}];
[%css {|accent-color: #ff0000|}];
[%css {|accent-color: rgb(255, 0, 0)|}];

/* touch-action */
[%css {|touch-action: auto|}];
[%css {|touch-action: none|}];
[%css {|touch-action: pan-x|}];
[%css {|touch-action: pan-y|}];
[%css {|touch-action: manipulation|}];
[%css {|touch-action: pan-x pan-y|}];

/* aspect-ratio */
[%css {|aspect-ratio: auto|}];
[%css {|aspect-ratio: 1 / 1|}];
[%css {|aspect-ratio: 16 / 9|}];
[%css {|aspect-ratio: 0.5|}];
