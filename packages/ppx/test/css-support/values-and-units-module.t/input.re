/* CSS Values and Units Module */
[%css {|width: 5rem|}];
[%css {|width: 5ch|}];
[%css {|width: 5vw|}];
[%css {|width: 5vh|}];
[%css {|width: 5vmin|}];
[%css {|width: 5vmax|}];
[%css {|width: calc(1px + 2px)|}];
[%css {|width: calc(5px * 2)|}];
[%css {|width: calc(5px * 2)|}];
[%css {|width: calc(5px - 10px)|}];
[%css {|width: calc(1vw - 1px)|}];
[%css {|width: 100%|}];
[%css {|padding: 5rem|}];
[%css {|padding: 5ch|}];
[%css {|padding: 5vw|}];
[%css {|padding: 5vh|}];
[%css {|padding: 5vmin|}];
[%css {|padding: 5vmax|}];
