/* CSS Container Queries Module Level 3 */
[%css {|container-type: normal|}];
[%css {|container-type: size|}];
[%css {|container-type: inline-size|}];
[%css {|container-name: none|}];
[%css {|container-name: sidebar|}];
[%css {|container-name: sidebar main|}];
[%css {|container: sidebar / inline-size|}];
[%css {|container: sidebar / size|}];
[%css {|container: none|}];
