External module aliases are canonicalized for aggregator lookup. The user writes
`$(Styles.marker)`, but the sentinel records `M.Css.marker` so the aggregator
can resolve it against M's exported [@@@css.bindings].

  $ refmt --parse re --print ml m.re > m.ml
  $ ../../standalone.exe --impl m.ml -o m.ml
  $ refmt --parse re --print ml n.re > n.ml
  $ ../../standalone.exe --impl n.ml -o n.ml

  $ cat n.ml
  [@@@css ".css-155k9s5-wrapper.\000M.Css.marker\000{color:blue;}"]
  [@@@css.bindings [("N.wrapper", "css-155k9s5-wrapper")]]
  [@@@css.refs [("M.Css.marker", "n.ml", 3, 6, 19)]]
  let _ = M.Css.marker
  module Styles = M.Css
  let wrapper = CSS.make_labeled "wrapper" "css-155k9s5-wrapper" []

  $ styled-ppx.generate m.ml n.ml > styles.css
  $ cat styles.css
  /* This file is generated by styled-ppx, do not edit manually */
  .css-155k9s5-wrapper.css-0-marker{color:blue;}
