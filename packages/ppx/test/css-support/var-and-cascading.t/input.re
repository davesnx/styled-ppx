/* CSS var() function */
[%css {|color: var(--primary-color)|}];
[%css {|background-color: var(--bg-color)|}];
[%css {|margin: var(--spacing)|}];
[%css {|padding: var(--padding)|}];
[%css {|font-size: var(--font-size)|}];
[%css {|width: var(--width)|}];
[%css {|height: var(--height)|}];

/* CSS-wide keywords (cascading) */
[%css {|color: inherit|}];
[%css {|color: initial|}];
[%css {|color: unset|}];
[%css {|color: revert|}];
[%css {|color: revert-layer|}];

[%css {|display: inherit|}];
[%css {|display: initial|}];
[%css {|display: unset|}];
[%css {|display: revert|}];
[%css {|display: revert-layer|}];

[%css {|margin: inherit|}];
[%css {|margin: initial|}];
[%css {|margin: unset|}];
[%css {|margin: revert|}];
[%css {|margin: revert-layer|}];

[%css {|flex: inherit|}];
[%css {|flex: initial|}];
[%css {|flex: unset|}];
[%css {|flex: revert|}];
[%css {|flex: revert-layer|}];

[%css {|font-size: inherit|}];
[%css {|font-size: initial|}];
[%css {|font-size: unset|}];
[%css {|font-size: revert|}];
[%css {|font-size: revert-layer|}];
