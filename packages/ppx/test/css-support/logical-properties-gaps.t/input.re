/* CSS Logical Properties Gaps - Extended coverage beyond existing test */

/* margin-block with various value types */
[%css {|margin-block-start: auto|}];
[%css {|margin-block-start: 0|}];
[%css {|margin-block-start: 10%|}];
[%css {|margin-block-start: calc(10px + 5%)|}];
[%css {|margin-block-end: auto|}];
[%css {|margin-block-end: 0|}];
[%css {|margin-block-end: 10%|}];
[%css {|margin-block-end: calc(10px + 5%)|}];

/* margin-inline with various value types */
[%css {|margin-inline-start: auto|}];
[%css {|margin-inline-start: 0|}];
[%css {|margin-inline-start: 10%|}];
[%css {|margin-inline-start: calc(10px + 5%)|}];
[%css {|margin-inline-end: auto|}];
[%css {|margin-inline-end: 0|}];
[%css {|margin-inline-end: 10%|}];
[%css {|margin-inline-end: calc(10px + 5%)|}];

/* padding-block with various value types */
[%css {|padding-block-start: 0|}];
[%css {|padding-block-start: 10%|}];
[%css {|padding-block-start: calc(10px + 5%)|}];
[%css {|padding-block-end: 0|}];
[%css {|padding-block-end: 10%|}];
[%css {|padding-block-end: calc(10px + 5%)|}];

/* padding-inline with various value types */
[%css {|padding-inline-start: 0|}];
[%css {|padding-inline-start: 10%|}];
[%css {|padding-inline-start: calc(10px + 5%)|}];
[%css {|padding-inline-end: 0|}];
[%css {|padding-inline-end: 10%|}];
[%css {|padding-inline-end: calc(10px + 5%)|}];

/* margin-block/inline shorthand with two values */
[%css {|margin-block: auto auto|}];
[%css {|margin-block: 10px 20px|}];
[%css {|margin-block: 10% 20%|}];
[%css {|margin-inline: auto auto|}];
[%css {|margin-inline: 10px 20px|}];
[%css {|margin-inline: 10% 20%|}];

/* padding-block/inline shorthand with two values */
[%css {|padding-block: 10px 20px|}];
[%css {|padding-block: 10% 20%|}];
[%css {|padding-inline: 10px 20px|}];
[%css {|padding-inline: 10% 20%|}];

/* border-block/inline width shorthand */
[%css {|border-block-width: thin|}];
[%css {|border-block-width: medium|}];
[%css {|border-block-width: thick|}];
[%css {|border-block-width: 2px|}];
[%css {|border-inline-width: thin|}];
[%css {|border-inline-width: medium|}];
[%css {|border-inline-width: thick|}];
[%css {|border-inline-width: 2px|}];

/* border-block/inline style shorthand */
[%css {|border-block-style: none|}];
[%css {|border-block-style: solid|}];
[%css {|border-block-style: dashed|}];
[%css {|border-inline-style: none|}];
[%css {|border-inline-style: solid|}];
[%css {|border-inline-style: dashed|}];
