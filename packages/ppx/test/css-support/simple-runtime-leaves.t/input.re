/* Small exact-match runtime leaves */
[%css {|empty-cells: show|}];
[%css {|empty-cells: hide|}];
[%css {|field-sizing: content|}];
[%css {|field-sizing: fixed|}];
[%css {|interpolate-size: numeric-only|}];
[%css {|interpolate-size: allow-keywords|}];
[%css {|initial-letter: normal|}];
[%css {|initial-letter: 1.5|}];
[%css {|initial-letter: 1.5 2|}];
[%css {|initial-letter-align: auto|}];
[%css {|initial-letter-align: alphabetic|}];
[%css {|initial-letter-align: hanging|}];
[%css {|initial-letter-align: ideographic|}];
[%css {|image-resolution: from-image|}];
[%css {|image-resolution: 96dpi|}];
[%css {|image-resolution: 2dppx|}];
[%css {|image-resolution: from-image snap|}];
[%css {|image-resolution: 96dpi snap|}];
