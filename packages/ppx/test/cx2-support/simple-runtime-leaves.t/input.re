/* Small exact-match runtime leaves */
[%cx2 {|empty-cells: show|}];
[%cx2 {|empty-cells: hide|}];
[%cx2 {|field-sizing: content|}];
[%cx2 {|field-sizing: fixed|}];
[%cx2 {|interpolate-size: numeric-only|}];
[%cx2 {|interpolate-size: allow-keywords|}];
[%cx2 {|initial-letter: normal|}];
[%cx2 {|initial-letter: 1.5|}];
[%cx2 {|initial-letter: 1.5 2|}];
[%cx2 {|initial-letter-align: auto|}];
[%cx2 {|initial-letter-align: alphabetic|}];
[%cx2 {|initial-letter-align: hanging|}];
[%cx2 {|initial-letter-align: ideographic|}];
[%cx2 {|image-resolution: from-image|}];
[%cx2 {|image-resolution: 96dpi|}];
[%cx2 {|image-resolution: 2dppx|}];
[%cx2 {|image-resolution: from-image snap|}];
[%cx2 {|image-resolution: 96dpi snap|}];
