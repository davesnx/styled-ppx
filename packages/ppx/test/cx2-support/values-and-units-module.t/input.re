/* CSS Values and Units Module */
[%cx2 {|width: 5rem|}];
[%cx2 {|width: 5ch|}];
[%cx2 {|width: 5vw|}];
[%cx2 {|width: 5vh|}];
[%cx2 {|width: 5vmin|}];
[%cx2 {|width: 5vmax|}];
[%cx2 {|width: calc(1px + 2px)|}];
[%cx2 {|width: calc(5px * 2)|}];
[%cx2 {|width: calc(5px * 2)|}];
[%cx2 {|width: calc(5px - 10px)|}];
[%cx2 {|width: calc(1vw - 1px)|}];
[%cx2 {|width: 100%|}];
[%cx2 {|padding: 5rem|}];
[%cx2 {|padding: 5ch|}];
[%cx2 {|padding: 5vw|}];
[%cx2 {|padding: 5vh|}];
[%cx2 {|padding: 5vmin|}];
[%cx2 {|padding: 5vmax|}];
