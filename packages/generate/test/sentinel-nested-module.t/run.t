The PPX emits fully-qualified longidents in `[@@@css.bindings ...]`,
including nested submodules. The aggregator just looks them up in the
flat index — no AST walking, no module-path reconstruction.

  $ cat > a.ml <<EOF
  > [@@@css.bindings [
  >   ("A.top", "top-leaf");
  >   ("A.Inner.near", "near-leaf");
  >   ("A.Inner.DeepInner.leaf", "deep-leaf")
  > ]]
  > module Inner = struct
  >   module DeepInner = struct
  >     let leaf = CSS.make "deep-leaf" []
  >   end
  >   let near = CSS.make "near-leaf" []
  > end
  > let top = CSS.make "top-leaf" []
  > EOF

  $ cat > b.ml <<EOF
  > [@@@css ".x.\000A.top\000.\000A.Inner.near\000.\000A.Inner.DeepInner.leaf\000{}"]
  > [@@@css.refs [
  >   ("A.top", "b.ml", 1, 0, 5);
  >   ("A.Inner.near", "b.ml", 1, 0, 12);
  >   ("A.Inner.DeepInner.leaf", "b.ml", 1, 0, 22)
  > ]]
  > let _ = A.top
  > let _ = A.Inner.near
  > let _ = A.Inner.DeepInner.leaf
  > EOF

  $ styled-ppx.generate a.ml b.ml
  /* This file is generated by styled-ppx, do not edit manually */
  .x.top-leaf.near-leaf.deep-leaf{}
